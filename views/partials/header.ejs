<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Всероссийская общественная организация ветеранов</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<!-- Top bar -->
<div class="topbar">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center">
      <div class="topbar-contacts">
        <span><i class="fas fa-phone"></i> (499) 241-34-01</span>
        <span class="ms-3"><i class="fas fa-envelope"></i> sovet.veteranov@bk.ru</span>
      </div>
      <div class="topbar-right">
        <span><i class="fas fa-clock"></i> Пн–Пт: 9:00–18:00</span>
      </div>
    </div>
  </div>
</div>

<!-- Header -->
<header class="site-header">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between py-3">
      <a href="/" class="header-logo d-flex align-items-center text-decoration-none">
        <div class="logo-emblem me-3">
          <% if (locals.siteSettings && siteSettings.logo) { %>
            <img src="<%= siteSettings.logo %>" alt="Логотип" style="width:60px;height:60px;object-fit:contain">
          <% } else { %>
          <svg viewBox="0 0 60 60" width="60" height="60" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="shieldGrad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#1B3A6B"/>
                <stop offset="100%" stop-color="#0F2347"/>
              </linearGradient>
            </defs>
            <path d="M7,5 H53 V33 Q53,51 30,59 Q7,51 7,33 Z" fill="url(#shieldGrad)"/>
            <path d="M7,5 H53 V33 Q53,51 30,59 Q7,51 7,33 Z" fill="none" stroke="#C03030" stroke-width="2.5"/>
            <path d="M11,9 H49 V33 Q49,48 30,55 Q11,48 11,33 Z" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
            <polygon points="30,14 33.5,24.1 44,24.6 35.8,31.4 38.6,42 30,36.2 21.4,42 24.2,31.4 16,24.6 26.5,24.1" fill="#ffffff"/>
          </svg>
          <% } %>
        </div>
        <div class="logo-text">
          <div class="logo-title">Всероссийская общественная организация ветеранов</div>
          <div class="logo-subtitle">(пенсионеров) войны, труда, Вооружённых Сил и правоохранительных органов</div>
        </div>
      </a>
    </div>
  </div>
</header>

<!-- Navigation -->
<nav class="main-nav navbar navbar-expand-lg">
  <div class="container">
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link <%= locals.activePage === 'home' ? 'active' : '' %>" href="/">
            <i class="fas fa-home"></i> Главная
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= locals.activePage === 'about' ? 'active' : '' %>" href="/about">
            <i class="fas fa-info-circle"></i> Об организации
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= locals.activePage === 'news' ? 'active' : '' %>" href="/news">
            <i class="fas fa-newspaper"></i> Новости
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= locals.activePage === 'activity' ? 'active' : '' %>" href="/activity">
            <i class="fas fa-hands-helping"></i> Деятельность
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= locals.activePage === 'gallery' ? 'active' : '' %>" href="/gallery">
            <i class="fas fa-images"></i> Галерея
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= locals.activePage === 'regions' ? 'active' : '' %>" href="/regions">
            <i class="fas fa-map-marked-alt"></i> Региональные организации
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= locals.activePage === 'documents' ? 'active' : '' %>" href="/documents">
            <i class="fas fa-file-alt"></i> Документы
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= locals.activePage === 'contacts' ? 'active' : '' %>" href="/contacts">
            <i class="fas fa-map-marker-alt"></i> Контакты
          </a>
        </li>
      </ul>
      <div class="nav-admin-link">
        <a href="/admin" class="btn btn-admin-sm">
          <i class="fas fa-lock"></i> Администратор
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- Flash messages -->
<% if (locals.flash_success && flash_success.length > 0) { %>
<div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
  <div class="container"><%= flash_success[0] %></div>
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>
<% if (locals.flash_error && flash_error.length > 0) { %>
<div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert">
  <div class="container"><%= flash_error[0] %></div>
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>
