<%- include('partials/header') %>

<div class="page-banner">
  <div class="container">
    <h1 class="page-banner-title">Об организации</h1>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Главная</a></li>
        <li class="breadcrumb-item active">Об организации</li>
      </ol>
    </nav>
  </div>
</div>

<div class="container mt-5 mb-5">

  <!-- ── 1. История ─────────────────────────────────────────────────────────── -->
  <section class="about-section mb-5">
    <div class="about-section-label"><i class="fas fa-history me-2"></i>История</div>
    <h2 class="about-section-title">История организации</h2>
    <div class="content-divider"></div>
    <div class="row">
      <div class="col-lg-9">
        <p class="about-text">
          Всероссийская общественная организация ветеранов (пенсионеров) войны, труда, Вооружённых Сил
          и правоохранительных органов была основана в 1991 году. В переломный момент истории страны
          ветераны объединились, чтобы отстаивать свои права, сохранять память о подвигах защитников
          Отечества и передавать её новым поколениям. За более чем тридцать лет организация выросла
          в крупнейшее ветеранское объединение России, насчитывающее свыше 14 000 первичных организаций
          в 85 регионах страны и объединяющее более 20 миллионов человек.
        </p>
      </div>
    </div>
  </section>

  <hr class="about-divider">

  <!-- ── 2. Структура ───────────────────────────────────────────────────────── -->
  <section class="about-section my-5">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <div class="about-section-label"><i class="fas fa-sitemap me-2"></i>Структура</div>
        <h2 class="about-section-title">Структура организации</h2>
        <div class="content-divider"></div>
        <p class="about-text">
          Организация построена по территориально-производственному принципу и включает четыре уровня:
          Центральный Совет, региональные советы в 85 субъектах Российской Федерации, районные
          (городские) советы и первичные организации на предприятиях, в учреждениях и по месту
          жительства ветеранов.
        </p>
        <div class="structure-levels mt-4">
          <div class="structure-level-item">
            <div class="slevel-dot slevel-1"></div>
            <div><strong>Центральный Совет</strong> — высший руководящий орган</div>
          </div>
          <div class="structure-level-item">
            <div class="slevel-dot slevel-2"></div>
            <div><strong>Региональные советы</strong> — 85 субъектов РФ</div>
          </div>
          <div class="structure-level-item">
            <div class="slevel-dot slevel-3"></div>
            <div><strong>Районные (городские) советы</strong> — муниципальный уровень</div>
          </div>
          <div class="structure-level-item">
            <div class="slevel-dot slevel-4"></div>
            <div><strong>Первичные организации</strong> — более 14 000 по стране</div>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <% if (structureImage) { %>
          <img src="<%= structureImage %>" alt="Структура организации"
            class="img-fluid rounded-3 w-100" style="max-height:380px;object-fit:cover;box-shadow:0 12px 40px rgba(0,0,0,0.12)">
        <% } else { %>
          <div class="about-img-placeholder">
            <i class="fas fa-sitemap"></i>
            <span>Изображение структуры</span>
            <small>Загрузите в Настройках → «Изображение структуры»</small>
          </div>
        <% } %>
      </div>
    </div>
  </section>

  <hr class="about-divider">

  <!-- ── 3. Руководящие органы ─────────────────────────────────────────────── -->
  <section class="about-section mt-5">
    <div class="about-section-label"><i class="fas fa-users me-2"></i>Руководящие органы</div>
    <h2 class="about-section-title mb-5">Руководящие органы организации</h2>

    <!-- Съезд -->
    <div class="governing-block mb-5">
      <h3 class="governing-title"><span class="governing-num">01</span>Съезд</h3>
      <div class="row align-items-center g-4 mt-1">
        <div class="col-lg-7">
          <p class="about-text">
            Съезд является высшим руководящим органом организации. Он созывается не реже одного раза
            в пять лет, определяет основные направления деятельности, утверждает устав, избирает
            Центральный Совет и Председателя организации.
          </p>
        </div>
        <% if (chairman) { %>
        <div class="col-lg-5">
          <div class="chairman-card">
            <div class="chairman-photo-wrap">
              <% if (chairman.photo) { %>
                <img src="<%= chairman.photo %>" alt="<%= chairman.name %>" class="chairman-photo">
              <% } else { %>
                <div class="chairman-photo-placeholder"><i class="fas fa-user"></i></div>
              <% } %>
            </div>
            <div class="chairman-info">
              <div class="chairman-badge">Председатель</div>
              <div class="chairman-name"><%= chairman.name %></div>
              <div class="chairman-position"><%= chairman.position %></div>
              <% if (chairman.bio) { %>
              <blockquote class="chairman-quote">
                "<%= chairman.bio.length > 160 ? chairman.bio.substring(0, 160) + '…' : chairman.bio %>"
              </blockquote>
              <% } %>
            </div>
          </div>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Центральный Совет -->
    <div class="governing-block mb-5">
      <h3 class="governing-title"><span class="governing-num">02</span>Центральный Совет</h3>
      <div class="row mt-1">
        <div class="col-lg-7">
          <p class="about-text">
            Центральный Совет — постоянно действующий руководящий орган организации между съездами.
            Осуществляет руководство деятельностью организации, рассматривает важнейшие вопросы
            работы с ветеранами, утверждает бюджет и отчёты о деятельности.
          </p>
          <a href="/documents" class="btn-governing-doc">
            <i class="fas fa-file-pdf me-2"></i>Полный состав Центрального Совета
            <i class="fas fa-arrow-right ms-2"></i>
          </a>
        </div>
      </div>
    </div>

    <!-- Бюро Центрального Совета -->
    <div class="governing-block mb-5">
      <h3 class="governing-title"><span class="governing-num">03</span>Бюро Центрального Совета</h3>
      <p class="about-text mt-1 mb-4">
        Бюро Центрального Совета осуществляет оперативное руководство деятельностью организации
        в период между заседаниями Центрального Совета.
      </p>
      <% if (bureau && bureau.length > 0) { %>
      <div class="row g-3">
        <% bureau.forEach(member => { %>
        <div class="col-lg-3 col-md-4 col-sm-6">
          <div class="bureau-card">
            <div class="bureau-photo-wrap">
              <% if (member.photo) { %>
                <img src="<%= member.photo %>" alt="<%= member.name %>" class="bureau-photo">
              <% } else { %>
                <div class="bureau-photo-placeholder"><i class="fas fa-user"></i></div>
              <% } %>
            </div>
            <div class="bureau-info">
              <div class="bureau-name"><%= member.name %></div>
              <div class="bureau-position"><%= member.position %></div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="empty-state">
        <i class="fas fa-users fa-2x text-muted mb-2"></i>
        <p>Добавьте членов через <a href="/admin/leaders">панель управления</a></p>
      </div>
      <% } %>
    </div>

    <!-- Аппарат организации -->
    <div class="governing-block">
      <h3 class="governing-title"><span class="governing-num">04</span>Аппарат организации</h3>
      <p class="about-text mt-1 mb-4">
        Аппарат организации обеспечивает организационную, правовую и информационно-аналитическую
        деятельность, координирует работу структурных подразделений и региональных советов.
      </p>
      <% if (staff && staff.length > 0) { %>
      <div class="row g-4">
        <% staff.forEach(member => { %>
        <div class="col-lg-4 col-md-6">
          <div class="staff-card">
            <div class="staff-photo-wrap">
              <% if (member.photo) { %>
                <img src="<%= member.photo %>" alt="<%= member.name %>" class="staff-photo">
              <% } else { %>
                <div class="staff-photo-placeholder"><i class="fas fa-user-tie"></i></div>
              <% } %>
            </div>
            <div class="staff-info">
              <div class="staff-name"><%= member.name %></div>
              <div class="staff-position"><%= member.position %></div>
              <% if (member.bio) { %>
              <p class="staff-bio"><%= member.bio %></p>
              <% } %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="empty-state">
        <i class="fas fa-user-tie fa-2x text-muted mb-2"></i>
        <p>Добавьте сотрудников через <a href="/admin/leaders">панель управления</a> с ролью «Аппарат»</p>
      </div>
      <% } %>
    </div>

  </section>
</div>

<%- include('partials/footer') %>

<style>
.about-section-label {
  font-size: 0.78rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 1.2px; color: var(--accent); margin-bottom: 8px;
}
.about-section-title {
  font-size: 1.9rem; font-weight: 700; color: var(--primary); margin-bottom: 0;
}
.about-text { font-size: 1rem; line-height: 1.85; color: #444; margin-bottom: 12px; }
.about-divider { border-color: rgba(27,58,107,0.1); }

/* Structure levels */
.structure-levels { display: flex; flex-direction: column; gap: 14px; }
.structure-level-item {
  display: flex; align-items: center; gap: 14px;
  font-size: 0.95rem; color: var(--text);
}
.slevel-dot {
  width: 14px; height: 14px; border-radius: 50%; flex-shrink: 0;
}
.slevel-1 { background: var(--accent); }
.slevel-2 { background: var(--primary); }
.slevel-3 { background: var(--primary-light); }
.slevel-4 { background: #aaa; }

/* Placeholder */
.about-img-placeholder {
  height: 320px; border-radius: 16px;
  background: #f0f2f5; border: 2px dashed #ccd;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  color: #aaa; gap: 10px; font-size: 0.9rem;
}
.about-img-placeholder i { font-size: 3rem; }
.about-img-placeholder small { font-size: 0.78rem; color: #bbb; }

/* Governing blocks */
.governing-block {
  padding: 32px; background: #fff; border-radius: var(--radius);
  box-shadow: var(--shadow); border: 1px solid rgba(27,58,107,0.06);
}
.governing-title {
  font-size: 1.25rem; font-weight: 700; color: var(--primary);
  display: flex; align-items: center; gap: 14px; margin-bottom: 0;
}
.governing-num {
  font-size: 2rem; font-weight: 900; color: rgba(27,58,107,0.1);
  line-height: 1; flex-shrink: 0;
}

/* Chairman */
.chairman-card {
  display: flex; gap: 20px; align-items: flex-start;
  background: var(--bg); padding: 20px; border-radius: var(--radius);
  border-left: 4px solid var(--accent);
}
.chairman-photo { width: 90px; height: 90px; border-radius: 50%; object-fit: cover; border: 3px solid var(--primary); flex-shrink: 0; }
.chairman-photo-placeholder {
  width: 90px; height: 90px; border-radius: 50%; flex-shrink: 0;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,0.5); font-size: 2.2rem;
}
.chairman-badge {
  font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.5px; background: var(--accent); color: #fff;
  padding: 2px 10px; border-radius: 20px; display: inline-block; margin-bottom: 6px;
}
.chairman-name { font-size: 1rem; font-weight: 700; color: var(--primary); margin-bottom: 2px; }
.chairman-position { font-size: 0.82rem; color: var(--accent); font-weight: 600; margin-bottom: 8px; }
.chairman-quote {
  font-size: 0.85rem; color: #555; font-style: italic; line-height: 1.6;
  border: none; margin: 0; padding: 0;
}

/* Document link */
.btn-governing-doc {
  display: inline-flex; align-items: center;
  padding: 11px 24px; border-radius: var(--radius-pill);
  background: var(--primary); color: #fff;
  font-size: 0.88rem; font-weight: 600; text-decoration: none;
  transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
  margin-top: 8px;
}
.btn-governing-doc:hover {
  background: var(--accent); color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 6px 18px rgba(150,32,32,0.22);
}

/* Bureau */
.bureau-card {
  background: #fff; border-radius: var(--radius);
  box-shadow: var(--shadow); overflow: hidden;
  border: 1px solid rgba(27,58,107,0.06);
  transition: transform var(--transition), box-shadow var(--transition);
  text-align: center;
}
.bureau-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
.bureau-photo-wrap { padding: 20px 20px 0; }
.bureau-photo { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 2px solid var(--primary); }
.bureau-photo-placeholder {
  width: 80px; height: 80px; border-radius: 50%; margin: 0 auto;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,0.5); font-size: 1.8rem;
}
.bureau-info { padding: 12px 14px 16px; }
.bureau-name { font-size: 0.88rem; font-weight: 700; color: var(--primary); line-height: 1.3; margin-bottom: 4px; }
.bureau-position { font-size: 0.76rem; color: var(--text-muted); line-height: 1.3; }

/* Staff */
.staff-card {
  display: flex; gap: 16px; align-items: flex-start;
  background: #fff; border-radius: var(--radius);
  box-shadow: var(--shadow); padding: 20px;
  border: 1px solid rgba(27,58,107,0.06);
  transition: transform var(--transition), box-shadow var(--transition);
  height: 100%;
}
.staff-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
.staff-photo { width: 72px; height: 72px; border-radius: 50%; object-fit: cover; border: 2px solid var(--primary); flex-shrink: 0; }
.staff-photo-placeholder {
  width: 72px; height: 72px; border-radius: 50%; flex-shrink: 0;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,0.5); font-size: 1.6rem;
}
.staff-name { font-size: 0.95rem; font-weight: 700; color: var(--primary); margin-bottom: 3px; }
.staff-position { font-size: 0.8rem; color: var(--accent); font-weight: 600; margin-bottom: 6px; }
.staff-bio { font-size: 0.82rem; color: var(--text-muted); line-height: 1.55; margin: 0; }
</style>
