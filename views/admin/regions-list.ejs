<%
  locals.activePage = 'regions';
%>
<%- include('partials/admin-layout-top') %>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title"><i class="fas fa-map-marked-alt me-2"></i>Региональные организации</h2>
  <a href="/admin/regions/new" class="btn btn-danger btn-sm">
    <i class="fas fa-plus me-1"></i>Добавить регион
  </a>
</div>

<div class="admin-card">
  <div class="admin-card-body p-0">
    <% if (regions && regions.length > 0) { %>
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th style="width:50px">#</th>
          <th>Город</th>
          <th>Название организации</th>
          <th class="d-none d-lg-table-cell">Председатель</th>
          <th class="d-none d-md-table-cell">Телефон</th>
          <th style="width:110px"></th>
        </tr>
      </thead>
      <tbody>
        <% regions.forEach(r => { %>
        <tr>
          <td class="text-muted"><%= r.sort_order || '' %></td>
          <td class="fw-medium"><%= r.city %></td>
          <td class="text-muted small"><%= r.name %></td>
          <td class="d-none d-lg-table-cell small"><%= r.chairman || '—' %></td>
          <td class="d-none d-md-table-cell small"><%= r.phone %></td>
          <td>
            <a href="/admin/regions/<%= r.id %>/edit" class="btn btn-sm btn-outline-secondary me-1">
              <i class="fas fa-edit"></i>
            </a>
            <form action="/admin/regions/<%= r.id %>/delete" method="POST" class="d-inline"
              onsubmit="return confirm('Удалить регион «<%= r.city %>»?')">
              <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="fas fa-trash"></i>
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } else { %>
    <div class="empty-state">
      <i class="fas fa-map-marked-alt fa-3x text-muted mb-3"></i>
      <p>Региональных организаций пока нет</p>
      <a href="/admin/regions/new" class="btn btn-danger btn-sm">Добавить первую</a>
    </div>
    <% } %>
  </div>
</div>

<%- include('partials/admin-layout-bottom') %>
