<%
  locals.activePage = 'documents';
  locals.flash_success = flash_success;
  locals.flash_error = flash_error;
%>
<%- include('partials/admin-layout-top') %>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title"><i class="fas fa-file-alt me-2"></i>Управление документами</h2>
</div>

<!-- Upload form -->
<div class="admin-card mb-4">
  <div class="admin-card-header"><h5 class="mb-0"><i class="fas fa-upload me-2"></i>Загрузить документ</h5></div>
  <div class="admin-card-body">
    <form action="/admin/documents/new" method="POST" enctype="multipart/form-data">
      <div class="row g-3 align-items-end">
        <div class="col-md-4">
          <label class="form-label fw-medium">Название документа</label>
          <input type="text" name="title" class="form-control" required placeholder="Название">
        </div>
        <div class="col-md-3">
          <label class="form-label fw-medium">Категория</label>
          <select name="category" class="form-select">
            <option>Общие</option>
            <option>Устав и положения</option>
            <option>Нормативные документы</option>
            <option>Отчёты</option>
            <option>Протоколы</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-medium">Файл</label>
          <input type="file" name="file" class="form-control" required>
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-danger w-100">
            <i class="fas fa-upload me-1"></i>Загрузить
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Documents table -->
<div class="admin-card">
  <div class="admin-card-body p-0">
    <% if (documents.length > 0) { %>
    <div class="table-responsive">
      <table class="table table-hover admin-table mb-0">
        <thead>
          <tr><th>Название</th><th>Категория</th><th>Дата</th><th>Действия</th></tr>
        </thead>
        <tbody>
          <% documents.forEach(d => { %>
          <tr>
            <td>
              <i class="fas fa-file-pdf text-danger me-2"></i>
              <%= d.title %>
            </td>
            <td><span class="badge bg-secondary"><%= d.category %></span></td>
            <td class="text-muted small">
              <%= new Date(d.uploaded_at).toLocaleDateString('ru-RU') %>
            </td>
            <td>
              <div class="d-flex gap-1">
                <a href="<%= d.filename %>" target="_blank" class="btn btn-xs btn-outline-secondary">
                  <i class="fas fa-eye"></i>
                </a>
                <form action="/admin/documents/<%= d.id %>/delete" method="POST"
                      onsubmit="return confirm('Удалить документ?')">
                  <button type="submit" class="btn btn-xs btn-outline-danger">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="text-center p-5 text-muted">
      <i class="fas fa-folder-open fa-3x mb-3"></i>
      <p>Документов нет</p>
    </div>
    <% } %>
  </div>
</div>

<%- include('partials/admin-layout-bottom') %>
