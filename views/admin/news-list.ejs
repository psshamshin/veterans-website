<%
  locals.activePage = 'news';
  locals.flash_success = flash_success;
  locals.flash_error = flash_error;
%>
<%- include('partials/admin-layout-top') %>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title"><i class="fas fa-newspaper me-2"></i>Управление новостями</h2>
  <a href="/admin/news/new" class="btn btn-danger">
    <i class="fas fa-plus me-1"></i>Добавить новость
  </a>
</div>

<div class="admin-card">
  <div class="admin-card-body p-0">
    <% if (news.length > 0) { %>
    <div class="table-responsive">
      <table class="table table-hover admin-table mb-0">
        <thead>
          <tr>
            <th style="width:50px">#</th>
            <th>Заголовок</th>
            <th>Категория</th>
            <th>Дата</th>
            <th>Статус</th>
            <th style="width:120px">Действия</th>
          </tr>
        </thead>
        <tbody>
          <% news.forEach((item, i) => { %>
          <tr>
            <td class="text-muted"><%= item.id %></td>
            <td>
              <div class="d-flex align-items-center">
                <% if (item.image) { %>
                <img src="<%= item.image %>" alt="" class="table-thumb me-2">
                <% } %>
                <div>
                  <div class="fw-medium"><%= item.title %></div>
                  <div class="small text-muted"><%= (item.excerpt || '').substring(0, 60) %></div>
                </div>
              </div>
            </td>
            <td><span class="badge bg-secondary"><%= item.category %></span></td>
            <td class="text-nowrap text-muted small">
              <%= new Date(item.published_at).toLocaleDateString('ru-RU', {day:'2-digit',month:'2-digit',year:'numeric'}) %>
            </td>
            <td>
              <% if (item.is_published) { %>
              <span class="badge bg-success">Опубликована</span>
              <% } else { %>
              <span class="badge bg-warning text-dark">Черновик</span>
              <% } %>
            </td>
            <td>
              <div class="d-flex gap-1">
                <a href="/news/<%= item.id %>" target="_blank" class="btn btn-xs btn-outline-secondary" title="Просмотр">
                  <i class="fas fa-eye"></i>
                </a>
                <a href="/admin/news/<%= item.id %>/edit" class="btn btn-xs btn-outline-primary" title="Редактировать">
                  <i class="fas fa-edit"></i>
                </a>
                <form action="/admin/news/<%= item.id %>/delete" method="POST" class="d-inline"
                      onsubmit="return confirm('Удалить эту новость?')">
                  <button type="submit" class="btn btn-xs btn-outline-danger" title="Удалить">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="text-center p-5 text-muted">
      <i class="fas fa-newspaper fa-3x mb-3"></i>
      <p>Новостей нет. <a href="/admin/news/new">Добавить первую новость</a></p>
    </div>
    <% } %>
  </div>
</div>

<%- include('partials/admin-layout-bottom') %>
