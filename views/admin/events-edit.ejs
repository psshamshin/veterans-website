<%
  locals.activePage = 'events';
  locals.flash_success = flash_success;
  locals.flash_error = flash_error;
%>
<%- include('partials/admin-layout-top') %>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title">
    <i class="fas fa-<%= item ? 'edit' : 'plus-circle' %> me-2"></i>
    <%= item ? 'Редактировать мероприятие' : 'Добавить мероприятие' %>
  </h2>
  <a href="/admin/events" class="btn btn-outline-secondary btn-sm">
    <i class="fas fa-arrow-left me-1"></i>Назад
  </a>
</div>

<div class="admin-card" style="max-width:700px">
  <div class="admin-card-body">
    <form action="/admin/events/<%= item ? item.id + '/edit' : 'new' %>" method="POST">
      <div class="mb-3">
        <label class="form-label fw-medium">Название мероприятия <span class="text-danger">*</span></label>
        <input type="text" name="title" class="form-control" required
          value="<%= item ? item.title : '' %>" placeholder="Введите название">
      </div>
      <div class="mb-3">
        <label class="form-label fw-medium">Описание</label>
        <textarea name="description" class="form-control" rows="5"
          placeholder="Подробное описание мероприятия..."><%= item ? item.description || '' : '' %></textarea>
      </div>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label fw-medium">Дата <span class="text-danger">*</span></label>
          <input type="date" name="event_date" class="form-control" required
            value="<%= item ? item.event_date : '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label fw-medium">Место проведения</label>
          <input type="text" name="location" class="form-control"
            value="<%= item ? item.location || '' : '' %>" placeholder="Адрес или название места">
        </div>
      </div>
      <div class="mt-3">
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" name="is_past" id="isPast"
            <%= item && item.is_past ? 'checked' : '' %>>
          <label class="form-check-label" for="isPast">Отметить как прошедшее</label>
        </div>
      </div>
      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-danger">
          <i class="fas fa-save me-1"></i><%= item ? 'Сохранить' : 'Добавить' %>
        </button>
        <a href="/admin/events" class="btn btn-outline-secondary">Отмена</a>
      </div>
    </form>
  </div>
</div>

<%- include('partials/admin-layout-bottom') %>
