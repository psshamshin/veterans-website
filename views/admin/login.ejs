<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Вход — Панель управления</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-login-body">

<div class="login-container">
  <div class="login-card">
    <div class="login-logo">
      <svg viewBox="0 0 60 60" width="56" height="56">
        <circle cx="30" cy="30" r="28" fill="#CC0000" stroke="#FFD700" stroke-width="2"/>
        <polygon points="30,8 33,22 47,22 36,31 40,45 30,37 20,45 24,31 13,22 27,22" fill="#FFD700"/>
        <circle cx="30" cy="30" r="10" fill="#1B3A6B"/>
      </svg>
    </div>
    <h4 class="login-title">Панель управления</h4>
    <p class="login-subtitle">Совет ветеранов России</p>

    <% if (locals.flash_error && flash_error && flash_error.length > 0) { %>
    <div class="alert alert-danger py-2"><%= flash_error[0] %></div>
    <% } %>

    <form action="/admin/login" method="POST">
      <div class="mb-3">
        <label class="form-label">Логин</label>
        <div class="input-group">
          <span class="input-group-text"><i class="fas fa-user"></i></span>
          <input type="text" name="username" class="form-control" placeholder="Логин" required autofocus>
        </div>
      </div>
      <div class="mb-4">
        <label class="form-label">Пароль</label>
        <div class="input-group">
          <span class="input-group-text"><i class="fas fa-lock"></i></span>
          <input type="password" name="password" class="form-control" placeholder="Пароль" required>
        </div>
      </div>
      <button type="submit" class="btn btn-danger w-100 py-2">
        <i class="fas fa-sign-in-alt me-2"></i>Войти
      </button>
    </form>

    <div class="mt-3 text-center">
      <a href="/" class="text-muted small"><i class="fas fa-arrow-left me-1"></i>На сайт</a>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
