<%
  locals.activePage = 'news';
  locals.flash_success = flash_success;
  locals.flash_error = flash_error;
%>
<%- include('partials/admin-layout-top') %>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title">
    <i class="fas fa-<%= item ? 'edit' : 'plus-circle' %> me-2"></i>
    <%= item ? 'Редактировать новость' : 'Добавить новость' %>
  </h2>
  <a href="/admin/news" class="btn btn-outline-secondary btn-sm">
    <i class="fas fa-arrow-left me-1"></i>Назад
  </a>
</div>

<form action="/admin/news/<%= item ? item.id + '/edit' : 'new' %>" method="POST" enctype="multipart/form-data">
  <div class="row g-4">
    <div class="col-lg-8">
      <div class="admin-card">
        <div class="admin-card-header"><h5 class="mb-0">Содержание новости</h5></div>
        <div class="admin-card-body">
          <div class="mb-3">
            <label class="form-label fw-medium">Заголовок <span class="text-danger">*</span></label>
            <input type="text" name="title" class="form-control" required
              value="<%= item ? item.title : '' %>" placeholder="Введите заголовок новости">
          </div>
          <div class="mb-3">
            <label class="form-label fw-medium">Краткое описание (для превью)</label>
            <textarea name="excerpt" class="form-control" rows="3"
              placeholder="Краткое описание для отображения в списке новостей..."><%= item ? item.excerpt || '' : '' %></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label fw-medium">Полный текст <span class="text-danger">*</span></label>
            <textarea name="content" id="newsContent" class="form-control rich-editor" rows="15"
              required><%= item ? item.content : '' %></textarea>
            <div class="form-text">Можно использовать HTML-теги: &lt;p&gt;, &lt;strong&gt;, &lt;em&gt;, &lt;ul&gt;, &lt;li&gt;</div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="admin-card">
        <div class="admin-card-header"><h5 class="mb-0">Настройки</h5></div>
        <div class="admin-card-body">
          <div class="mb-3">
            <label class="form-label fw-medium">Категория</label>
            <select name="category" class="form-select">
              <option value="Новости организации" <%= (!item || item.category === 'Новости организации') ? 'selected' : '' %>>Новости организации</option>
              <option value="Новости в регионах" <%= (item && item.category === 'Новости в регионах') ? 'selected' : '' %>>Новости в регионах</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-medium">Дата публикации</label>
            <input type="datetime-local" name="published_at" class="form-control"
              value="<%= item ? new Date(item.published_at).toISOString().slice(0,16) : new Date().toISOString().slice(0,16) %>">
          </div>
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" name="is_published" id="isPublished"
                <%= (!item || item.is_published) ? 'checked' : '' %>>
              <label class="form-check-label" for="isPublished">Опубликовать</label>
            </div>
          </div>
        </div>
      </div>

      <div class="admin-card mt-3">
        <div class="admin-card-header"><h5 class="mb-0">Изображение</h5></div>
        <div class="admin-card-body">
          <% if (item && item.image) { %>
          <div class="current-image mb-3">
            <img src="<%= item.image %>" alt="Текущее изображение" class="img-fluid rounded" style="max-height:150px">
            <div class="small text-muted mt-1">Текущее изображение</div>
          </div>
          <% } %>
          <label class="form-label fw-medium">
            <%= item && item.image ? 'Заменить изображение' : 'Загрузить изображение' %>
          </label>
          <input type="file" name="image" id="newsImageInput" class="form-control" accept="image/*"
            data-crop-ratio="16/9" data-preview-id="newsImagePreview">
          <img id="newsImagePreview" src="" alt="Превью" class="img-fluid rounded mt-2"
            style="max-height:160px;display:none">
          <div class="form-text">Форматы: JPG, PNG. Макс. 50 МБ. Кроп 16:9 применится автоматически.</div>
        </div>
      </div>

      <div class="mt-3 d-grid gap-2">
        <button type="submit" class="btn btn-danger btn-lg">
          <i class="fas fa-save me-2"></i><%= item ? 'Сохранить изменения' : 'Добавить новость' %>
        </button>
        <a href="/admin/news" class="btn btn-outline-secondary">Отмена</a>
      </div>
    </div>
  </div>
</form>

<%- include('partials/admin-layout-bottom') %>
