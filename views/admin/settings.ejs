<%
  locals.activePage = 'settings';
  locals.flash_success = flash_success;
  locals.flash_error = flash_error;
%>
<%- include('partials/admin-layout-top') %>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title">
    <i class="fas fa-cog me-2"></i>Настройки сайта
  </h2>
</div>

<div class="row g-4">
  <!-- Logo -->
  <div class="col-lg-6">
    <div class="admin-card">
      <div class="admin-card-header">
        <h5 class="mb-0"><i class="fas fa-image me-2"></i>Логотип сайта</h5>
      </div>
      <div class="admin-card-body">
        <% if (currentLogo) { %>
        <div class="mb-3 text-center">
          <p class="text-muted small mb-2">Текущий логотип:</p>
          <img src="<%= currentLogo %>" alt="Логотип" class="img-fluid rounded"
            style="max-height:100px;background:#f0f0f0;padding:8px;border:1px solid #ddd">
        </div>
        <% } else { %>
        <div class="mb-3 text-center p-3 rounded" style="background:#f5f5f7;border:2px dashed #ddd">
          <i class="fas fa-image fa-2x text-muted"></i>
          <div class="small text-muted mt-1">Логотип не загружен — используется SVG-щит</div>
        </div>
        <% } %>

        <form action="/admin/settings/logo" method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label fw-medium">Загрузить новый логотип</label>
            <input type="file" name="logo" id="logoInput" class="form-control" accept="image/*"
              data-crop-ratio="" data-preview-id="logoPreview">
            <img id="logoPreview" src="" alt="Превью" class="mt-2 rounded"
              style="max-height:80px;display:none">
            <div class="form-text">PNG с прозрачным фоном рекомендуется. Размер: 60×60px или больше.</div>
          </div>
          <button type="submit" class="btn btn-danger">
            <i class="fas fa-upload me-1"></i>Загрузить логотип
          </button>
        </form>

        <% if (currentLogo) { %>
        <form action="/admin/settings/logo/delete" method="POST" class="mt-3">
          <button type="submit" class="btn btn-outline-secondary btn-sm"
            onclick="return confirm('Удалить логотип и вернуть стандартный щит?')">
            <i class="fas fa-trash me-1"></i>Удалить и вернуть SVG-логотип
          </button>
        </form>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Password change -->
  <div class="col-lg-6">
    <div class="admin-card">
      <div class="admin-card-header">
        <h5 class="mb-0"><i class="fas fa-key me-2"></i>Смена пароля администратора</h5>
      </div>
      <div class="admin-card-body">
        <form action="/admin/settings/password" method="POST">
          <div class="mb-3">
            <label class="form-label fw-medium">Текущий пароль</label>
            <input type="password" name="current_password" class="form-control" required placeholder="Введите текущий пароль">
          </div>
          <div class="mb-3">
            <label class="form-label fw-medium">Новый пароль</label>
            <input type="password" name="new_password" class="form-control" required minlength="6" placeholder="Минимум 6 символов">
          </div>
          <div class="mb-4">
            <label class="form-label fw-medium">Повторить новый пароль</label>
            <input type="password" name="confirm_password" class="form-control" required placeholder="Повторите новый пароль">
          </div>
          <button type="submit" class="btn btn-danger">
            <i class="fas fa-save me-1"></i>Сменить пароль
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('partials/admin-layout-bottom') %>
