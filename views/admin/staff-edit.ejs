<%
  locals.activePage = 'staff';
  locals.flash_success = flash_success;
  locals.flash_error = flash_error;
%>
<%- include('partials/admin-layout-top') %>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title">
    <i class="fas fa-<%= item ? 'edit' : 'user-plus' %> me-2"></i>
    <%= item ? 'Редактировать сотрудника' : 'Добавить сотрудника' %>
  </h2>
  <a href="/admin/staff" class="btn btn-outline-secondary btn-sm">
    <i class="fas fa-arrow-left me-1"></i>Назад
  </a>
</div>

<div class="admin-card" style="max-width:700px">
  <div class="admin-card-body">
    <form action="/admin/staff/<%= item ? item.id + '/edit' : 'new' %>" method="POST" enctype="multipart/form-data">
      <div class="row g-3">
        <div class="col-md-8">
          <label class="form-label fw-medium">ФИО <span class="text-danger">*</span></label>
          <input type="text" name="name" class="form-control" required
            value="<%= item ? item.name : '' %>" placeholder="Фамилия Имя Отчество">
        </div>
        <div class="col-md-4">
          <label class="form-label fw-medium">Порядок сортировки</label>
          <input type="number" name="sort_order" class="form-control"
            value="<%= item ? item.sort_order : 0 %>" min="0">
        </div>
        <div class="col-12">
          <label class="form-label fw-medium">Должность <span class="text-danger">*</span></label>
          <input type="text" name="position" class="form-control" required
            value="<%= item ? item.position : '' %>" placeholder="Должность в организации">
        </div>
        <div class="col-12">
          <label class="form-label fw-medium">Краткая справка</label>
          <textarea name="bio" class="form-control" rows="5"
            placeholder="Краткая биография, достижения, звания..."><%= item ? item.bio || '' : '' %></textarea>
        </div>
        <div class="col-12">
          <label class="form-label fw-medium">
            <%= item && item.photo ? 'Заменить фото' : 'Фото' %>
          </label>
          <% if (item && item.photo) { %>
          <div class="mb-2">
            <img src="<%= item.photo %>" alt="" class="rounded" style="max-height:120px">
          </div>
          <% } %>
          <input type="file" name="photo" id="staffPhotoInput" class="form-control" accept="image/*"
            data-crop-ratio="1" data-preview-id="staffPhotoPreview">
          <img id="staffPhotoPreview" src="" alt="" class="rounded mt-2" style="max-height:120px;display:none">
          <div class="form-text">JPG, PNG. Кроп 1:1 (квадрат).</div>
        </div>
      </div>
      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-danger">
          <i class="fas fa-save me-1"></i><%= item ? 'Сохранить' : 'Добавить' %>
        </button>
        <a href="/admin/staff" class="btn btn-outline-secondary">Отмена</a>
      </div>
    </form>
  </div>
</div>

<%- include('partials/admin-layout-bottom') %>
