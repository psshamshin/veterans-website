<%
  locals.activePage = 'leaders';
  locals.flash_success = flash_success;
  locals.flash_error = flash_error;
%>
<%- include('partials/admin-layout-top') %>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title"><i class="fas fa-users me-2"></i>Руководящий состав</h2>
  <a href="/admin/leaders/new" class="btn btn-danger">
    <i class="fas fa-plus me-1"></i>Добавить
  </a>
</div>

<div class="admin-card">
  <div class="admin-card-body p-0">
    <% if (leaders.length > 0) { %>
    <div class="table-responsive">
      <table class="table table-hover admin-table mb-0">
        <thead>
          <tr>
            <th>Порядок</th><th>ФИО</th><th>Должность</th><th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <% leaders.forEach(l => { %>
          <tr>
            <td class="text-center"><%= l.sort_order %></td>
            <td>
              <div class="d-flex align-items-center">
                <% if (l.photo) { %>
                <img src="<%= l.photo %>" alt="" class="rounded-circle me-2" width="40" height="40" style="object-fit:cover">
                <% } else { %>
                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center me-2"
                     style="width:40px;height:40px;flex-shrink:0">
                  <i class="fas fa-user text-white small"></i>
                </div>
                <% } %>
                <div class="fw-medium"><%= l.name %></div>
              </div>
            </td>
            <td class="text-muted"><%= l.position %></td>
            <td>
              <div class="d-flex gap-1">
                <a href="/admin/leaders/<%= l.id %>/edit" class="btn btn-xs btn-outline-primary">
                  <i class="fas fa-edit"></i>
                </a>
                <form action="/admin/leaders/<%= l.id %>/delete" method="POST"
                      onsubmit="return confirm('Удалить этого руководителя?')">
                  <button type="submit" class="btn btn-xs btn-outline-danger">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="text-center p-5 text-muted">
      <i class="fas fa-users fa-3x mb-3"></i>
      <p>Нет данных. <a href="/admin/leaders/new">Добавить первого руководителя</a></p>
    </div>
    <% } %>
  </div>
</div>

<%- include('partials/admin-layout-bottom') %>
