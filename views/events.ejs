<%- include('partials/header') %>

<div class="page-banner">
  <div class="container">
    <h1 class="page-banner-title">Мероприятия</h1>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Главная</a></li>
        <li class="breadcrumb-item active">Мероприятия</li>
      </ol>
    </nav>
  </div>
</div>

<div class="container mt-4 mb-5">

  <!-- Upcoming -->
  <div class="section-header mb-4">
    <h2 class="section-title"><i class="fas fa-calendar-check text-danger me-2"></i>Предстоящие мероприятия</h2>
  </div>

  <% if (upcoming.length > 0) { %>
  <div class="row g-3 mb-5">
    <% upcoming.forEach(ev => { %>
    <div class="col-md-6 col-lg-4">
      <div class="event-card">
        <% const d = new Date(ev.event_date); %>
        <div class="event-card-header">
          <div class="event-card-date">
            <span class="event-card-day"><%= d.getDate() %></span>
            <span class="event-card-month"><%= d.toLocaleDateString('ru-RU', {month:'long'}) %></span>
            <span class="event-card-year"><%= d.getFullYear() %></span>
          </div>
          <span class="event-card-status upcoming">Предстоит</span>
        </div>
        <div class="event-card-body">
          <h5 class="event-card-title"><%= ev.title %></h5>
          <% if (ev.description) { %>
          <p class="event-card-desc"><%= ev.description.substring(0, 150) %><% if (ev.description.length > 150) { %>...<% } %></p>
          <% } %>
          <% if (ev.location) { %>
          <div class="event-card-location">
            <i class="fas fa-map-marker-alt text-danger"></i>
            <%= ev.location %>
          </div>
          <% } %>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } else { %>
  <div class="empty-state mb-5">
    <i class="fas fa-calendar-alt fa-3x text-muted mb-3"></i>
    <p>Предстоящих мероприятий нет</p>
  </div>
  <% } %>

  <!-- Past events -->
  <% if (past.length > 0) { %>
  <div class="section-header mb-4">
    <h2 class="section-title"><i class="fas fa-history text-secondary me-2"></i>Прошедшие мероприятия</h2>
  </div>
  <div class="row g-3">
    <% past.forEach(ev => { %>
    <div class="col-md-6 col-lg-4">
      <div class="event-card past">
        <% const d = new Date(ev.event_date); %>
        <div class="event-card-header">
          <div class="event-card-date">
            <span class="event-card-day"><%= d.getDate() %></span>
            <span class="event-card-month"><%= d.toLocaleDateString('ru-RU', {month:'long'}) %></span>
            <span class="event-card-year"><%= d.getFullYear() %></span>
          </div>
          <span class="event-card-status past-label">Прошло</span>
        </div>
        <div class="event-card-body">
          <h5 class="event-card-title"><%= ev.title %></h5>
          <% if (ev.description) { %>
          <p class="event-card-desc"><%= ev.description.substring(0, 150) %><% if (ev.description.length > 150) { %>...<% } %></p>
          <% } %>
          <% if (ev.location) { %>
          <div class="event-card-location">
            <i class="fas fa-map-marker-alt"></i>
            <%= ev.location %>
          </div>
          <% } %>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>

</div>

<%- include('partials/footer') %>
