<%- include('partials/header') %>

<!-- Hero Banner -->
<section class="hero-section">
  <div class="hero-overlay">
    <div class="container">
      <div class="row align-items-center g-4">
        <div class="col-lg-6">
          <div class="hero-content" style="padding:60px 0">
            <h1 class="hero-title">Всероссийская общественная организация ветеранов</h1>
            <p class="hero-subtitle">(пенсионеров) войны, труда, Вооружённых Сил и правоохранительных органов</p>
            <div class="hero-buttons">
              <a href="/about" class="btn btn-hero-primary">О нас</a>
              <a href="/contacts" class="btn btn-hero-secondary">Связаться с нами</a>
            </div>
          </div>
        </div>
        <div class="col-lg-6 d-none d-lg-block py-4">
          <div id="heroCarousel" class="carousel slide hero-carousel" data-bs-ride="carousel" data-bs-interval="4000">
            <div class="carousel-inner">
              <% const heroSlides = [heroSlide1, heroSlide2, heroSlide3].filter(Boolean); %>
              <% if (heroSlides.length > 0) { %>
                <% heroSlides.forEach((slide, i) => { %>
                <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                  <img src="<%= slide %>" alt="Слайд <%= i+1 %>" class="hero-carousel-img">
                </div>
                <% }) %>
              <% } else { %>
                <div class="carousel-item active">
                  <div class="hero-carousel-placeholder">
                    <i class="fas fa-image"></i>
                    <span>Загрузите фотографии в настройках</span>
                  </div>
                </div>
              <% } %>
            </div>
            <% if (heroSlides.length > 1) { %>
            <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
              <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
              <span class="carousel-control-next-icon"></span>
            </button>
            <div class="carousel-indicators hero-carousel-indicators">
              <% heroSlides.forEach((_, i) => { %>
              <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="<%= i %>"
                class="<%= i === 0 ? 'active' : '' %>"></button>
              <% }) %>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Stats Strip -->
<section class="stats-strip">
  <div class="container">
    <div class="row g-0">
      <div class="col-6 col-md-3">
        <div class="stat-item">
          <div class="stat-number">14 000+</div>
          <div class="stat-label">Первичных организаций</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-item">
          <div class="stat-number">79</div>
          <div class="stat-label">Лет со Дня Победы</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-item">
          <div class="stat-number">85</div>
          <div class="stat-label">Регионов России</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-item">
          <div class="stat-number">30+</div>
          <div class="stat-label">Лет объединяем ветеранов</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Main Content -->
<div class="container mt-4">
  <div class="row g-4">

    <!-- News Column -->
    <div class="col-lg-8">
      <div class="section-header">
        <h2 class="section-title"><i class="fas fa-newspaper text-danger me-2"></i>Новости</h2>
        <a href="/news" class="section-link">Все новости <i class="fas fa-arrow-right"></i></a>
      </div>

      <% if (news.length > 0) { %>
        <!-- Featured news -->
        <div class="news-featured mb-4">
          <% const featured = news[0]; %>
          <div class="card news-card-featured">
            <% if (featured.image) { %>
            <div class="news-card-img-wrap">
              <img src="<%= featured.image %>" alt="<%= featured.title %>" class="card-img-top news-card-img">
            </div>
            <% } else { %>
            <div class="news-card-img-placeholder-lg">
              <i class="fas fa-newspaper"></i>
            </div>
            <% } %>
            <div class="card-body">
              <span class="news-category badge"><%= featured.category %></span>
              <h3 class="news-title-lg mt-2">
                <a href="/news/<%= featured.id %>"><%= featured.title %></a>
              </h3>
              <p class="news-excerpt"><%= featured.excerpt || featured.content.replace(/<[^>]*>/g, '').substring(0, 200) %>...</p>
              <div class="news-meta">
                <span><i class="fas fa-calendar"></i>
                  <%= new Date(featured.published_at).toLocaleDateString('ru-RU', {day:'numeric',month:'long',year:'numeric'}) %>
                </span>
              </div>
            </div>
          </div>
        </div>

        <!-- News grid -->
        <div class="row g-3" id="newsGrid">
          <% news.slice(1).forEach((item, idx) => { %>
          <div class="col-md-6 news-extra-item" style="<%= idx >= 5 ? 'display:none' : '' %>">
            <div class="card news-card h-100">
              <% if (item.image) { %>
              <img src="<%= item.image %>" alt="<%= item.title %>" class="card-img-top news-card-img-sm">
              <% } else { %>
              <div class="news-card-img-placeholder">
                <i class="fas fa-newspaper"></i>
              </div>
              <% } %>
              <div class="card-body">
                <span class="news-category badge badge-sm"><%= item.category %></span>
                <h5 class="news-title mt-1">
                  <a href="/news/<%= item.id %>"><%= item.title %></a>
                </h5>
                <p class="news-excerpt-sm"><%= (item.excerpt || item.content.replace(/<[^>]*>/g,'')).substring(0,120) %>...</p>
                <div class="news-meta-sm">
                  <span><i class="fas fa-calendar"></i>
                    <%= new Date(item.published_at).toLocaleDateString('ru-RU', {day:'numeric',month:'long',year:'numeric'}) %>
                  </span>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
        </div>

        <% if (news.length > 6) { %>
        <div class="text-center mt-4" id="loadMoreWrap">
          <button class="btn btn-load-more" id="loadMoreBtn" onclick="loadMoreNews()">
            <i class="fas fa-chevron-down me-2"></i>Загрузить ещё
            <span class="load-more-count">(<%= news.length - 6 %> новостей)</span>
          </button>
        </div>
        <% } %>

      <% } else { %>
        <div class="empty-state">
          <i class="fas fa-newspaper fa-3x text-muted mb-3"></i>
          <p>Новостей пока нет</p>
        </div>
      <% } %>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">

      <!-- Gallery widget -->
      <div class="sidebar-widget">
        <div class="widget-header">
          <h4><i class="fas fa-images"></i> Галерея</h4>
        </div>
        <div class="widget-body p-2">
          <% if (galleryPhotos && galleryPhotos.length > 0) { %>
          <div class="sidebar-gallery-grid">
            <% galleryPhotos.forEach(photo => { %>
            <a href="/news/<%= photo.id %>" class="sidebar-gallery-item" title="<%= photo.title %>">
              <img src="<%= photo.image %>" alt="<%= photo.title %>">
              <div class="sidebar-gallery-overlay"><i class="fas fa-arrow-right"></i></div>
            </a>
            <% }) %>
          </div>
          <a href="/gallery" class="btn-region-detail d-block text-center mt-3">
            <i class="fas fa-images me-1"></i> Вся галерея
          </a>
          <% } else { %>
            <p class="text-muted small text-center py-2">Фото появятся после публикации новостей с изображениями</p>
            <a href="/gallery" class="btn-region-detail d-block text-center mt-2">
              <i class="fas fa-images me-1"></i> Галерея
            </a>
          <% } %>
        </div>
      </div>

      <!-- Quick links -->
      <div class="sidebar-widget mt-4">
        <div class="widget-header">
          <h4><i class="fas fa-link"></i> Быстрые ссылки</h4>
        </div>
        <div class="widget-body p-0">
          <ul class="quick-links">
            <li><a href="/about"><i class="fas fa-chevron-right"></i> Об организации</a></li>
            <li><a href="/leadership"><i class="fas fa-chevron-right"></i> Руководящий состав</a></li>
            <li><a href="/documents"><i class="fas fa-chevron-right"></i> Нормативные документы</a></li>
            <li><a href="/contacts"><i class="fas fa-chevron-right"></i> Обратная связь</a></li>
          </ul>
        </div>
      </div>

      <!-- Contacts widget -->
      <div class="sidebar-widget mt-4">
        <div class="widget-header">
          <h4><i class="fas fa-address-card"></i> Контакты</h4>
        </div>
        <div class="widget-body">
          <div class="contact-info-item">
            <i class="fas fa-map-marker-alt text-danger"></i>
            <span>Денежный пер., д. 12, Москва, 119002</span>
          </div>
          <div class="contact-info-item">
            <i class="fas fa-phone text-danger"></i>
            <span>(499) 241-34-01</span>
          </div>
          <div class="contact-info-item">
            <i class="fas fa-envelope text-danger"></i>
            <span>sovet.veteranov@bk.ru</span>
          </div>
          <div class="contact-info-item">
            <i class="fas fa-clock text-danger"></i>
            <span>Пн–Пт: 9:00–18:00</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
.btn-load-more {
  background: #fff;
  border: 2px solid var(--primary);
  color: var(--primary);
  padding: 10px 32px;
  border-radius: var(--radius-pill);
  font-weight: 600;
  font-size: 0.9rem;
  transition: background var(--transition), color var(--transition), transform var(--transition), box-shadow var(--transition);
}
.btn-load-more:hover {
  background: var(--primary);
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 6px 18px rgba(27,58,107,0.2);
}
.load-more-count { font-weight: 400; opacity: 0.7; font-size: 0.85em; }
</style>

<script>
function loadMoreNews() {
  const hidden = document.querySelectorAll('.news-extra-item[style*="display:none"]');
  let shown = 0;
  hidden.forEach(function(el) {
    if (shown < 6) { el.style.display = ''; shown++; }
  });
  const remaining = document.querySelectorAll('.news-extra-item[style*="display:none"]').length;
  if (remaining === 0) {
    document.getElementById('loadMoreWrap').style.display = 'none';
  } else {
    document.querySelector('.load-more-count').textContent = '(' + remaining + ' новостей)';
  }
}
</script>

<%- include('partials/footer') %>
